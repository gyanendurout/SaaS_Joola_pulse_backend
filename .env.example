# =============================================================
# Template only — copy to `.env` and fill values there.
# Never commit real secrets to this file.
# =============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL_CHEAP=gpt-4o-mini
OPENAI_MODEL_SMART=gpt-4o

# --- DataForSEO --- (REQUIRED for Agent D / keyword research)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
# Anon (publishable) key — frontend uses this when calling Supabase directly.
# Not required for POC since the frontend goes through FastAPI.
SUPABASE_ANON_KEY=
# Service-role / secret key — backend uses this for all DB writes. REQUIRED.
SUPABASE_SERVICE_ROLE_KEY=
# Optional direct DB URL (only used if we bypass supabase-py).
SUPABASE_DB_URL=

# --- Apify (optional, off by default) ---
APIFY_TOKEN=
APIFY_ENABLED=false

# --- App ---
APP_ENV=local
STORAGE_DIR=./storage
DEFAULT_MARKET=US
DEFAULT_LANGUAGE=en
MAX_PAGES_PER_CRAWL=300
MAX_KEYWORDS_PER_PROJECT=500

# --- Hard caps (POC safety) ---
OPENAI_COST_CAP_USD_PER_RUN=5.0
CRAWL_CONCURRENCY=10
CRAWL_REQUEST_TIMEOUT_SEC=15
USER_AGENT=SEOIntelBot/0.1 (+internal POC; respects robots.txt)
