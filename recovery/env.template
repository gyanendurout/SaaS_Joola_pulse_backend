# JOOLA Pulse — Backend env template
# Copy this file to `backend/.env` and fill in real values.
# DO NOT commit the populated file.

# ---------------------------------------------------------------------------
# OpenAI — REQUIRED for AI enrichment, SEO recommendations, news summaries
# ---------------------------------------------------------------------------
OPENAI_API_KEY={{OPENAI_API_KEY}}
OPENAI_MODEL_CHEAP=gpt-4o-mini
OPENAI_MODEL_SMART=gpt-4o

# ---------------------------------------------------------------------------
# DataForSEO — REQUIRED for Agent D (keyword research, SERP, backlinks)
# Existing account: api@joola.com
# ---------------------------------------------------------------------------
DATAFORSEO_LOGIN={{DATAFORSEO_LOGIN}}
DATAFORSEO_PASSWORD={{DATAFORSEO_PASSWORD}}

# ---------------------------------------------------------------------------
# Supabase — REQUIRED
# ---------------------------------------------------------------------------
SUPABASE_URL={{SUPABASE_PROJECT_URL}}
# Anon key — not strictly needed (backend uses service role)
SUPABASE_ANON_KEY=
# Service-role / secret key — REQUIRED for all DB writes
SUPABASE_SERVICE_ROLE_KEY={{SUPABASE_SERVICE_ROLE_KEY}}
# Optional: direct DB URL (only used if bypassing supabase-py)
SUPABASE_DB_URL=

# ---------------------------------------------------------------------------
# Google Search Console — OPTIONAL (Step 8 in SEO analysis)
# Create credentials at https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID (Web application)
# 2. Add authorised redirect URI: <GOOGLE_REDIRECT_BASE_URL>/api/performance/callback/gsc
# 3. Enable "Google Search Console API" in the GCP project
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Apify — OPTIONAL, off by default. Backend code only uses Apify when
# APIFY_ENABLED=true. (The IG scraper at frontend/scripts/scrape_joola_ig.py
# reads APIFY_API_TOKEN separately from frontend/.env.local.)
# ---------------------------------------------------------------------------
APIFY_TOKEN={{APIFY_API_TOKEN}}
APIFY_ENABLED=false

# ---------------------------------------------------------------------------
# App-wide
# ---------------------------------------------------------------------------
APP_ENV=local            # local | staging | production
STORAGE_DIR=./storage
DEFAULT_MARKET=US
DEFAULT_LANGUAGE=en
MAX_PAGES_PER_CRAWL=300
MAX_KEYWORDS_PER_PROJECT=500

# Hard caps for POC safety — adjust upward if you trust the budget
OPENAI_COST_CAP_USD_PER_RUN=5.0
CRAWL_CONCURRENCY=10
CRAWL_REQUEST_TIMEOUT_SEC=15
USER_AGENT=SEOIntelBot/0.1 (+internal POC; respects robots.txt)
